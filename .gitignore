# ═══════════════════════════════════════════════════════════════════════════════
# ALPR Engine - .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ───────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ───────────────────────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ───────────────────────────────────────────────────────────────────────────────
# IDE
# ───────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ───────────────────────────────────────────────────────────────────────────────
# Jupyter
# ───────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/*.ipynb
!notebooks/.gitkeep

# ───────────────────────────────────────────────────────────────────────────────
# Tests
# ───────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ───────────────────────────────────────────────────────────────────────────────
# Data & Outputs
# ───────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ───────────────────────────────────────────────────────────────────────────────
# Models (poids)
# ───────────────────────────────────────────────────────────────────────────────
# Garder la structure, ignorer les gros fichiers
models/*.pt
models/*.pth
models/*.onnx
models/*.bin
!models/.gitkeep

# ───────────────────────────────────────────────────────────────────────────────
# MLflow
# ───────────────────────────────────────────────────────────────────────────────
mlruns/
mlartifacts/
*.mlmodel

# ───────────────────────────────────────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────────────────────────────────────
*.log
logs/
*.out
*.err

# ───────────────────────────────────────────────────────────────────────────────
# OS
# ───────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ───────────────────────────────────────────────────────────────────────────────
# Secrets
# ───────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials/

# ───────────────────────────────────────────────────────────────────────────────
# Temporary
# ───────────────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# ───────────────────────────────────────────────────────────────────────────────
# Docker
# ───────────────────────────────────────────────────────────────────────────────
# Ignorer les volumes montés localement
docker/volumes/

# ───────────────────────────────────────────────────────────────────────────────
# Airflow
# ───────────────────────────────────────────────────────────────────────────────
airflow/logs/
airflow/plugins/
airflow.db
airflow.cfg
webserver_config.py

# ───────────────────────────────────────────────────────────────────────────────
# HuggingFace
# ───────────────────────────────────────────────────────────────────────────────
.cache/
hub/

# ───────────────────────────────────────────────────────────────────────────────
# Git placeholders (garder ces fichiers)
# ───────────────────────────────────────────────────────────────────────────────
!**/.gitkeep
