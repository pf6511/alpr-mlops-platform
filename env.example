# ═══════════════════════════════════════════════════════════════════════════════
# ALPR Engine - Variables d'environnement
# ═══════════════════════════════════════════════════════════════════════════════
# Copier ce fichier vers .env et remplir les valeurs
# cp .env.example .env

# ───────────────────────────────────────────────────────────────────────────────
# ENVIRONNEMENT
# ───────────────────────────────────────────────────────────────────────────────
ENV=development
# ENV=production
DEBUG=false

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE (Neon DB / PostgreSQL)
# ───────────────────────────────────────────────────────────────────────────────
# Mode: 'sqlite' (dev local) ou 'postgres' (production Neon DB)
DB_MODE=sqlite

# SQLite (dev local)
SQLITE_PATH=./alpr.db

# PostgreSQL / Neon DB (production)
# DB_MODE=postgres
# DB_HOST=ep-xxx-xxx-123456.eu-central-1.aws.neon.tech
# DB_PORT=5432
# DB_NAME=alpr
# DB_USER=alpr_user
# DB_PASSWORD=your_neon_password_here
# DB_SSLMODE=require

# ───────────────────────────────────────────────────────────────────────────────
# STOCKAGE S3 (AWS / Scaleway / MinIO)
# ───────────────────────────────────────────────────────────────────────────────
# Mode: 'local' (dev) ou 's3' (production)
STORAGE_MODE=local

# S3 Configuration (Scaleway exemple)
# STORAGE_MODE=s3
# S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
# S3_ACCESS_KEY=your_access_key_here
# S3_SECRET_KEY=your_secret_key_here
# S3_REGION=fr-par

# Buckets
# S3_DATASET_BUCKET=alpr-dataset
# S3_CAPTURES_BUCKET=alpr-captures
# S3_ARTIFACTS_BUCKET=mlflow-artifacts

# MinIO local (alternative dev)
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# ───────────────────────────────────────────────────────────────────────────────
# MLFLOW
# ───────────────────────────────────────────────────────────────────────────────
# Mode: 'local' (dev) ou 'remote' (production)
MLFLOW_MODE=local

# Local tracking
MLFLOW_TRACKING_URI=./mlruns

# Remote tracking server (production)
# MLFLOW_MODE=remote
# MLFLOW_TRACKING_URI=http://mlflow.your-domain.com:5000
# MLFLOW_REGISTRY_URI=http://mlflow.your-domain.com:5000

# Experiment
MLFLOW_EXPERIMENT=alpr-engine

# Noms des modèles dans le registry
MLFLOW_YOLO_PLATE=yolo-plate-detector
MLFLOW_YOLO_VEHICLE=yolo-vehicle-detector
MLFLOW_EFFICIENTNET=efficientnet-brand-classifier

# ───────────────────────────────────────────────────────────────────────────────
# RAY SERVE
# ───────────────────────────────────────────────────────────────────────────────
# Mode: 'local' (dev, appels directs) ou 'serve' (production Ray Serve)
RAY_MODE=local

# Ray Cluster
# RAY_MODE=serve
# RAY_ADDRESS=auto
# RAY_HTTP_HOST=0.0.0.0
# RAY_HTTP_PORT=8000

# Replicas par modèle
# RAY_YOLO_REPLICAS=2
# RAY_OCR_REPLICAS=1
# RAY_EFFICIENTNET_REPLICAS=1

# GPU par replica (fraction)
# RAY_NUM_GPUS=0.25

# ───────────────────────────────────────────────────────────────────────────────
# AIRFLOW
# ───────────────────────────────────────────────────────────────────────────────
AIRFLOW_DAG_ID=alpr_retrain_efficientnet
AIRFLOW_SCHEDULE=@daily

# Seuil minimum d'images pour déclencher le retraining
AIRFLOW_MIN_DATASET=500

# ───────────────────────────────────────────────────────────────────────────────
# LIGHTNING AI (Fine-tuning GPU)
# ───────────────────────────────────────────────────────────────────────────────
# LIGHTNING_API_KEY=your_lightning_api_key
# LIGHTNING_STUDIO_ID=your_studio_id

# ───────────────────────────────────────────────────────────────────────────────
# MODÈLES ML
# ───────────────────────────────────────────────────────────────────────────────
# Chemins locaux (fallback si MLflow non disponible)
MODEL_YOLO_PLATE=./models/best.pt
MODEL_YOLO_VEHICLE=./models/yolov8s.pt
MODEL_EFFICIENTNET=./models/efficientnet_b4_brands.pt

# Seuils de confiance
MODEL_YOLO_CONF=0.5
MODEL_OCR_CONF=0.6
MODEL_BRAND_CONF=0.7

# ───────────────────────────────────────────────────────────────────────────────
# GRADIO
# ───────────────────────────────────────────────────────────────────────────────
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
GRADIO_MAX_FILE_SIZE=200MB
